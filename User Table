CREATE TABLE YOURLIB.USER_AUTHORITY
(
    USER_ID            VARCHAR(20) NOT NULL,
    USER_AUTHORITY     SMALLINT NOT NULL
                         CHECK (USER_AUTHORITY BETWEEN 0 AND 4),

    -- Add Audit Fields
    ADD_DATE           DATE NOT NULL
                         DEFAULT CURRENT_DATE,
    ADD_TIME           TIME NOT NULL
                         DEFAULT CURRENT_TIME,
    ADD_USER           VARCHAR(10) NOT NULL
                         DEFAULT USER,
    ADD_PROGRAM        VARCHAR(20),

    -- Change Audit Fields
    CHG_DATE           DATE,
    CHG_TIME           TIME,
    CHG_USER           VARCHAR(10),
    CHG_PROGRAM        VARCHAR(20),

    PRIMARY KEY (USER_ID),

    CONSTRAINT UK_USER_AUTHORITY
        UNIQUE (USER_ID)
);
