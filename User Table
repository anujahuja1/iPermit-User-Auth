CREATE TABLE MYLIB.USER_AUTHORITY
(
    USER_ID            VARCHAR(20) NOT NULL,
    USER_AUTHORITY     SMALLINT NOT NULL
                         CHECK (USER_AUTHORITY BETWEEN 0 AND 4),

    ADD_DATE           DATE NOT NULL DEFAULT CURRENT_DATE,
    ADD_TIME           TIME NOT NULL DEFAULT CURRENT_TIME,
    ADD_USER           VARCHAR(10) NOT NULL DEFAULT CURRENT USER,
    ADD_PROGRAM        VARCHAR(20),

    CHG_DATE           DATE,
    CHG_TIME           TIME,
    CHG_USER           VARCHAR(10),
    CHG_PROGRAM        VARCHAR(20),

    CONSTRAINT PK_USER_AUTHORITY
        PRIMARY KEY (USER_ID),

    CONSTRAINT FK_USER_AUTHORITY_USER
        FOREIGN KEY (USER_ID)
        REFERENCES MYLIB.USERS (USER_ID)
);
